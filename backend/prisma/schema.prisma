// FERB — schema do banco
// SQLite para desenvolvimento (zero infra, persiste no restart).
// Para migrar pra PostgreSQL: trocar provider="postgresql" e DATABASE_URL no .env.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────
// AGÊNCIA VIRTUAL
// ─────────────────────────────────────────────────────

model Agent {
  id        String   @id
  name      String
  title     String
  specialty String
  bio       String
  avatar    String
  color     String
  room      String
  mood      String   @default("idle")

  demands   Demand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Demand {
  id          String    @id @default(uuid())
  agentId     String
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  title       String
  description String
  priority    String    @default("medium") // low | medium | high
  status      String    @default("in_progress") // pending | in_progress | completed
  result      String?
  dueDate     DateTime?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([agentId])
  @@index([status])
}

// ─────────────────────────────────────────────────────
// TAREFAS (Home)
// ─────────────────────────────────────────────────────

model Task {
  id        String   @id @default(uuid())
  title     String
  status    String   @default("todo")    // todo | feita
  priority  String   @default("media")   // critica | alta | media | baixa
  ferb      Boolean  @default(false)      // sugerida pelo FERB?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────
// RELAÇÕES — CRM (contatos profissionais + oportunidades)
// ─────────────────────────────────────────────────────

model Contact {
  id           String        @id @default(uuid())
  name         String
  role         String?       // cargo/função — ex.: "A&R", "Promoter"
  company      String?       // selo, agência, marca
  type         String        @default("outro") // selo | promoter | produtor | marca | imprensa | outro
  email        String?
  phone        String?
  city         String?
  notes        String?
  lastContact  DateTime?     // último contato registrado

  opportunities Opportunity[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([type])
}

model Opportunity {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("aberta") // aberta | em_negociacao | ganha | perdida
  priority    String    @default("media")  // critica | alta | media | baixa
  value       Float?    // valor estimado em R$ (opcional)
  dueDate     DateTime?

  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([contactId])
}
