// FERB — schema do banco
// SQLite para desenvolvimento (zero infra, persiste no restart).
// Para migrar pra PostgreSQL: trocar provider="postgresql" e DATABASE_URL no .env.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────
// AGÊNCIA VIRTUAL
// ─────────────────────────────────────────────────────

model Agent {
  id        String   @id
  name      String
  title     String
  specialty String
  bio       String
  avatar    String
  color     String
  room      String
  mood      String   @default("idle")

  demands   Demand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Demand {
  id          String    @id @default(uuid())
  agentId     String
  agent       Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  title       String
  description String
  priority    String    @default("medium") // low | medium | high
  status      String    @default("in_progress") // pending | in_progress | completed
  result      String?
  dueDate     DateTime?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([agentId])
  @@index([status])
}

// ─────────────────────────────────────────────────────
// TAREFAS (Home)
// ─────────────────────────────────────────────────────

model Task {
  id        String   @id @default(uuid())
  title     String
  status    String   @default("todo")    // todo | feita
  priority  String   @default("media")   // critica | alta | media | baixa
  ferb      Boolean  @default(false)      // sugerida pelo FERB?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────
// RELAÇÕES — CRM (contatos profissionais + oportunidades)
// ─────────────────────────────────────────────────────

model Contact {
  id           String        @id @default(uuid())
  name         String
  role         String?       // cargo/função — ex.: "A&R", "Promoter"
  company      String?       // selo, agência, marca
  type         String        @default("outro") // selo | promoter | produtor | marca | imprensa | outro
  email        String?
  phone        String?
  city         String?
  notes        String?
  lastContact  DateTime?     // último contato registrado

  opportunities Opportunity[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([type])
}

model Opportunity {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("aberta") // aberta | em_negociacao | ganha | perdida
  priority    String    @default("media")  // critica | alta | media | baixa
  value       Float?    // valor estimado em R$ (opcional)
  dueDate     DateTime?

  contactId   String?
  contact     Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([contactId])
}

// ─────────────────────────────────────────────────────
// TIKTOK — token OAuth do artista (authorization_code flow)
// Single-artist: guardamos uma linha por conta conectada.
// ─────────────────────────────────────────────────────

model TikTokAuth {
  id               String   @id @default(uuid())
  openId           String   @unique          // identificador da conta TikTok
  accessToken      String
  refreshToken     String
  scope            String?                   // scopes concedidos
  expiresAt        DateTime                  // expiração do access_token
  refreshExpiresAt DateTime?                 // expiração do refresh_token
  displayName      String?
  avatarUrl        String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─────────────────────────────────────────────────────
// HISTÓRICO — snapshots de métricas + relatório diário
// ─────────────────────────────────────────────────────

model MetricSnapshot {
  id         String   @id @default(uuid())
  source     String   // chartmetric | youtube | deezer | lastfm | spotify
  metric     String   // ex.: monthly_listeners, subscribers, fans, listeners
  label      String   // rótulo legível — ex.: "Inscritos YouTube"
  value      Float
  capturedAt DateTime @default(now())

  @@index([metric])
  @@index([capturedAt])
}

model DailyReport {
  id        String   @id @default(uuid())
  date      DateTime @unique          // dia do relatório (meia-noite)
  summary   String                    // texto gerado pelo FERB
  status    String   @default("ok")   // ok | warning | critical
  metrics   String?                   // JSON com o resumo de métricas do dia
  createdAt DateTime @default(now())

  @@index([date])
}

// ─────────────────────────────────────────────────────
// CONCÍLIO — os 9 agentes debatem uma questão
// ─────────────────────────────────────────────────────

model Council {
  id        String   @id @default(uuid())
  question  String                    // a questão levada ao concílio
  takes     String                    // JSON: [{agentId, name, opinion}]
  synthesis String                    // síntese final do Gerente
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─────────────────────────────────────────────────────
// CENTRAL DE INTELIGÊNCIA — métricas diárias, baseline,
// detecção de anomalia e análise automática por IA.
// ─────────────────────────────────────────────────────

model DailyMetric {
  id                       String   @id @default(uuid())
  date                     DateTime @unique

  // Spotify (vários só vêm de CSV; ficam null sem upload do Spotify for Artists)
  spotifyListeners         Int?     // listeners do dia (CSV)
  spotifyMonthlyListeners  Int?
  spotifyMonthlyActive     Int?     // monthly active listeners (CSV)
  spotifyStreams           Int?
  spotifyPlaylistAdds      Int?
  spotifySaves             Int?
  spotifyFollowers         Int?
  spotifySuperListeners    Int?
  spotifyPopularity        Int?

  // YouTube
  youtubeSubscribers       Int?
  youtubeViews             Int?

  // Instagram / TikTok (via Chartmetric)
  instagramFollowers       Int?
  tiktokFollowers          Int?
  tiktokLikes              Int?

  // Outras plataformas
  deezerFans               Int?
  lastfmListeners          Int?
  lastfmPlaycount          Int?

  source                   String   @default("api")   // api | csv | manual
  createdAt                DateTime @default(now())

  @@index([date])
}

model BaselineSnapshot {
  id           String   @id                  // ex.: "spotifyStreams_7d_avg"
  type         String   @default("7d_avg")
  metric       String
  value        Float
  calculatedAt DateTime @default(now())

  @@index([metric, type])
}

model DetectedEvent {
  id            String   @id @default(uuid())
  type          String                       // spike_streams | drop_streams | viral_streams | ...
  severity      String   @default("medium")  // low | medium | high | critical
  platform      String                       // spotify | youtube | instagram | tiktok | all

  title         String
  description   String

  metricName    String
  currentValue  Float
  baselineValue Float
  changePct     Float

  contextData   String?  @default("{}")      // JSON livre

  status        String   @default("detected") // detected | analyzing | analyzed | actioned | dismissed
  detectedAt    DateTime @default(now())

  analysis      AutoAnalysis?

  @@index([detectedAt])
  @@index([status])
}

model AutoAnalysis {
  id              String   @id @default(uuid())
  eventId         String?  @unique

  trigger         String                       // event | scheduled | manual
  agentType       String                       // manager | marketer | arandr | techhacker | ...

  summary         String
  fullAnalysis    String
  recommendations String   @default("[]")      // JSON array
  contextUsed     String   @default("{}")      // JSON

  modelUsed       String   @default("claude-opus-4-5")
  tokensUsed      Int?

  generatedAt     DateTime @default(now())

  humanReview     String?                      // approved | rejected | modified
  humanNotes      String?
  reviewedAt      DateTime?

  event           DetectedEvent? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([generatedAt])
}
